# Quantiliom AI — frontend Firebase config
#
# These are the canonical Firebase web env variable names. The current site is
# served as static files (no bundler), so values are read at runtime from
# src/firebase-config.js — copy src/firebase-config.example.js and fill it in
# with the same values listed below. When the site is migrated to Vite, the
# same variables can be consumed via import.meta.env without changing code.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
